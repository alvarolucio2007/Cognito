<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="database.controller.PrincipalController"
      style="-fx-background-color: #001EE4; -fx-background-radius: 20;"
      prefWidth="440.0" prefHeight="950.0" spacing="0">

    <!-- Cabeçalho Azul Superior -->
    <VBox spacing="15.0" style="-fx-background-color: #001EE4;">
        <padding>
            <Insets top="50.0" right="24.0" bottom="15.0" left="24.0"/>
        </padding>

        <!-- Barra do Topo -->
        <HBox alignment="CENTER" spacing="0">
            <Button fx:id="botaoPerfil" onAction="#sair" prefWidth="44.0" prefHeight="44.0"
                    style="-fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 22; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-cursor: hand;"
                    text="👤"/>
            <Region HBox.hgrow="ALWAYS" />
            <Label text="Cognito" style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold; -fx-font-family: 'Georgia';"/>
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#irParaConfiguracoes" prefWidth="44.0" prefHeight="44.0"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 24px; -fx-cursor: hand;"
                    text="⚙"/>
        </HBox>

        <!-- Campo de Pesquisa -->
        <HBox alignment="CENTER_LEFT" spacing="10.0" 
              style="-fx-background-color: white; -fx-background-radius: 19; -fx-padding: 8 15 8 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 4);">
            <TextField promptText="Pesquisar Módulos" HBox.hgrow="ALWAYS"
                       style="-fx-background-color: transparent; -fx-prompt-text-fill: #888888; -fx-text-fill: #333333; -fx-font-size: 15px; -fx-padding: 0;"/>
            <Label text="🔍" style="-fx-text-fill: #0040ff; -fx-font-size: 16px;"/>
        </HBox>
    </VBox>

    <!-- Corpo Principal com Fundo Branco -->
    <StackPane VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 46 46 0 0;">
        
        <!-- ================= ABAS MULTIPLAS ================= -->
        
        <!-- ABA 1: scrollVideoAulas (Rolagem dos Vídeos) -->
        <ScrollPane fx:id="scrollVideoAulas" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    style="-fx-background: white; -fx-background-color: transparent; -fx-background-radius: 46 46 0 0; -fx-padding: 10 0 0 0;">
            <content>
                <VBox spacing="30.0" style="-fx-background-color: white; -fx-padding: 20 24 120 24;">
                    
                    <!-- Card 1 -->
                    <VBox fx:id="cardAula1" onMouseClicked="#abrirAula" spacing="10.0" style="-fx-cursor: hand;">
                        <StackPane prefHeight="190.0" style="-fx-background-radius: 29;">
                            <children>
                                <ImageView fx:id="imgAula1" fitWidth="392.0" fitHeight="190.0" preserveRatio="false">
                                    <image>
                                        <Image url="@/images/image-CardLesson01.png"/>
                                    </image>
                                </ImageView>
                            </children>
                        </StackPane>
                        <Label text="Introdução ao uso de IA e suas aplicações" 
                               style="-fx-text-fill: #000000; -fx-font-size: 18px; -fx-font-weight: bold; -fx-font-family: 'Quicksand';" wrapText="true"/>
                        <HBox>
                            <Label fx:id="labelAulas1" text="Aulas assistidas: 8/10" style="-fx-text-fill: #333333; -fx-font-size: 14px;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="labelAvaliacoes1" text="Avaliações feitas: 1/2" style="-fx-text-fill: #333333; -fx-font-size: 14px;"/>
                        </HBox>
                    </VBox>

                    <!-- Card 2 -->
                    <VBox fx:id="cardAula2" onMouseClicked="#abrirAula" spacing="10.0" style="-fx-cursor: hand;">
                        <StackPane prefHeight="190.0" style="-fx-background-radius: 29;">
                            <children>
                                <ImageView fx:id="imgAula2" fitWidth="392.0" fitHeight="190.0" preserveRatio="false">
                                    <image>
                                        <Image url="@/images/image-CardLesson02.png"/>
                                    </image>
                                </ImageView>
                            </children>
                        </StackPane>
                        <Label text="Atuação prática real com o uso de IA" 
                               style="-fx-text-fill: #000000; -fx-font-size: 18px; -fx-font-weight: bold; -fx-font-family: 'Quicksand';" wrapText="true"/>
                        <HBox>
                            <Label fx:id="labelAulas2" text="Aulas assistidas: 1/4" style="-fx-text-fill: #333333; -fx-font-size: 14px;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="labelAvaliacoes2" text="Avaliações feitas: 0/1" style="-fx-text-fill: #333333; -fx-font-size: 14px;"/>
                        </HBox>
                    </VBox>

                    <!-- Card 3 -->
                    <VBox fx:id="cardAula3" onMouseClicked="#abrirAula" spacing="10.0" style="-fx-cursor: hand;">
                        <StackPane prefHeight="190.0" style="-fx-background-radius: 29;">
                            <children>
                                <ImageView fx:id="imgAula3" fitWidth="392.0" fitHeight="190.0" preserveRatio="false">
                                    <image>
                                        <Image url="@/images/image-CardLesson03.png"/>
                                    </image>
                                </ImageView>
                            </children>
                        </StackPane>
                        <Label text="Uso de IA e tecnologia vestível" 
                               style="-fx-text-fill: #000000; -fx-font-size: 18px; -fx-font-weight: bold; -fx-font-family: 'Quicksand';" wrapText="true"/>
                        <HBox>
                            <Label fx:id="labelAulas3" text="Aulas assistidas: 0/4" style="-fx-text-fill: #333333; -fx-font-size: 14px;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="labelAvaliacoes3" text="Avaliações feitas: 0/2" style="-fx-text-fill: #333333; -fx-font-size: 14px;"/>
                        </HBox>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>

        <!-- ABA 2: scrollAtividades (A Trilha de Livros - Oculta por padrão) -->
        <ScrollPane fx:id="scrollAtividades" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    visible="false" managed="false"
                    style="-fx-background: white; -fx-background-color: transparent; -fx-background-radius: 46 46 0 0; -fx-padding: 10 0 0 0;">
            <content>
                <VBox spacing="35.0" alignment="TOP_CENTER" style="-fx-background-color: white; -fx-padding: 20 24 120 24;">
                    
                    <!-- Dropdown de Módulos (ComboBox) -->
                    <ComboBox fx:id="comboModulos" prefWidth="380.0" prefHeight="46.0"
                              promptText="Selecionar Módulo que Deseja Exercitar"
                              style="-fx-background-color: rgba(53, 73, 205, 0.15); -fx-background-radius: 20; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand;"/>

                    <!-- Estrela 3D Decorativa do Topo -->
                    <StackPane prefWidth="180.0" prefHeight="80.0" style="-fx-background-color: #5762ff; -fx-background-radius: 40; -fx-effect: dropshadow(gaussian, #000886, 15, 0, 0, 8);">
                        <children>
                            <Label text="⭐" style="-fx-text-fill: white; -fx-font-size: 32px;"/>
                        </children>
                    </StackPane>

                    <!-- Trilha em Formato de Cobra (Desvios de margem para o efeito) -->
                    <VBox spacing="25.0" alignment="TOP_CENTER">
                        
                        <!-- Livro 1 (Inicia a atividade 1) -->
                        <Button onAction="#abrirTrilhaAtividade" text="📖 1" prefWidth="90.0" prefHeight="55.0"
                                style="-fx-background-color: #5762ff; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-background-radius: 45; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, #000886, 10, 0, 0, 4);">
                            <VBox.margin>
                                <Insets left="150.0"/>
                            </VBox.margin>
                        </Button>

                        <!-- Livro 2 -->
                        <Button text="📖 2" prefWidth="90.0" prefHeight="55.0"
                                style="-fx-background-color: #5762ff; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-background-radius: 45; -fx-effect: dropshadow(gaussian, #000886, 10, 0, 0, 4);">
                            <VBox.margin>
                                <Insets left="50.0"/>
                            </VBox.margin>
                        </Button>

                        <!-- Livro 3 -->
                        <Button text="📖 3" prefWidth="90.0" prefHeight="55.0"
                                style="-fx-background-color: #5762ff; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-background-radius: 45; -fx-effect: dropshadow(gaussian, #000886, 10, 0, 0, 4);">
                            <VBox.margin>
                                <Insets right="50.0"/>
                            </VBox.margin>
                        </Button>

                        <!-- Livro 4 -->
                        <Button text="📖 4" prefWidth="90.0" prefHeight="55.0"
                                style="-fx-background-color: #5762ff; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-background-radius: 45; -fx-effect: dropshadow(gaussian, #000886, 10, 0, 0, 4);">
                            <VBox.margin>
                                <Insets right="150.0"/>
                            </VBox.margin>
                        </Button>

                        <!-- Livro 5 -->
                        <Button text="📖 5" prefWidth="90.0" prefHeight="55.0"
                                style="-fx-background-color: #5762ff; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-background-radius: 45; -fx-effect: dropshadow(gaussian, #000886, 10, 0, 0, 4);">
                            <VBox.margin>
                                <Insets right="50.0"/>
                            </VBox.margin>
                        </Button>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>

        <!-- Menu Flutuante de Seleção (Alternador de Abas) -->
        <VBox alignment="BOTTOM_CENTER" mouseTransparent="false" pickOnBounds="false">
            <padding>
                <Insets bottom="30.0"/>
            </padding>
            <HBox alignment="CENTER" maxWidth="347.0" prefHeight="50.0"
                  style="-fx-background-color: rgba(107, 107, 107, 0.15); -fx-background-radius: 10; -fx-padding: 4; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 4);">
                <children>
                    <!-- Botão Vídeo Aulas -->
                    <Button fx:id="abaVideoBtn" text="Vídeo Aulas" onAction="#mostrarAbaVideo" prefWidth="165.0" prefHeight="42.0"
                            style="-fx-background-color: #a0a6ff; -fx-text-fill: #000dc9; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;"/>
                    
                    <!-- Divisor central -->
                    <Region prefWidth="1" prefHeight="32" style="-fx-background-color: #b1b1b1;" />
                    
                    <!-- Botão Atividades -->
                    <Button fx:id="abaAtividadesBtn" text="Atividades" onAction="#mostrarAbaAtividades" prefWidth="165.0" prefHeight="42.0"
                            style="-fx-background-color: transparent; -fx-text-fill: #000000; -fx-font-size: 16px; -fx-cursor: hand;"/>
                </children>
            </HBox>
        </VBox>
    </StackPane>
</VBox>
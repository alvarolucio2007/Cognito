<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="database.controller.TesteNivelamentoController"
      alignment="TOP_CENTER" spacing="30.0"
      style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 30, 0, 0, 8);"
      prefWidth="440.0" prefHeight="950.0">

    <padding>
        <Insets top="80.0" right="30.0" bottom="30.0" left="30.0"/>
    </padding>

    <!-- Título idêntico ao protótipo da imagem -->
    <Label text="Teste de nivelamento" style="-fx-text-fill: #0D1B54; -fx-font-size: 28px; -fx-font-weight: bold;" wrapText="true" textAlignment="CENTER"/>
    
    <Label text="Antes de prosseguir, queremos fazer algumas perguntas" style="-fx-text-fill: #3B52E2; -fx-font-size: 18px; -fx-text-alignment: center;" wrapText="true" textAlignment="CENTER">
        <padding>
            <Insets bottom="20.0"/>
        </padding>
    </Label>

    <!-- Pergunta 1: Há quanto tempo possui celular (DatePicker) -->
    <VBox spacing="12.0" alignment="CENTER">
        <Label text="A quanto tempo possui um telefone celular?" style="-fx-text-fill: #333333; -fx-font-size: 16px; -fx-font-weight: 500;"/>
        <DatePicker fx:id="dataPosseCelular" promptText="Data" prefWidth="280.0" style="-fx-background-color: white; -fx-border-color: #D1D5DB; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 15px;"/>
    </VBox>

    <!-- Pergunta 2: Assistente de voz (Botões Sim e Não do design) -->
    <VBox spacing="15.0" alignment="CENTER">
        <Label text="Você já falou (&quot;Ok google&quot; ou &quot;E aí, siri&quot;) para executar alguma ajuda?" style="-fx-text-fill: #333333; -fx-font-size: 16px; -fx-font-weight: bold; -fx-text-alignment: center;" wrapText="true" textAlignment="CENTER"/>
        <HBox spacing="15.0" alignment="CENTER">
            <Button fx:id="botaoSim" text="Sim" onAction="#selecionarSim" prefWidth="120.0" prefHeight="45.0"
                    style="-fx-background-color: #D6E0FF; -fx-text-fill: #3B52E2; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-border-color: #3B52E2; -fx-border-radius: 10; -fx-cursor: hand;"/>
            <Button fx:id="botaoNao" text="Não" onAction="#selecionarNao" prefWidth="120.0" prefHeight="45.0"
                    style="-fx-background-color: #0A145C; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;"/>
        </HBox>
    </VBox>

    <Region VBox.vgrow="ALWAYS" />

    <Label fx:id="labelAviso" style="-fx-text-fill: #DC2626; -fx-font-size: 14px;" wrapText="true" textAlignment="CENTER"/>

    <!-- Botão principal Continuar do design -->
    <Button fx:id="botaoContinuar" text="Continuar" onAction="#salvarNivelamento"
            style="-fx-background-color: #001EE4; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;"
            prefWidth="320.0" prefHeight="55.0"/>
</VBox>
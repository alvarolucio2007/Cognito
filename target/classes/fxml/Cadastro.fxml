<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="database.controller.UsuarioController"
      alignment="TOP_CENTER"
      spacing="8"
      style="-fx-background-color: linear-gradient(to bottom, #E8EAF6, #C5CAE9);
             -fx-background-radius: 20;"
      prefWidth="440.0" prefHeight="950.0">

    <padding>
        <Insets top="36" right="32" bottom="36" left="32"/>
    </padding>

    <!-- logo Oficial do Sistema (Readicionado aqui) -->
    <StackPane>
        <padding><Insets bottom="8"/></padding>
        <ImageView fitWidth="160.0" fitHeight="160.0" preserveRatio="true">
            <image>
                <Image url="@/images/logo_sistema.png"/>
            </image>
        </ImageView>
    </StackPane>

    <!-- Título -->
    <Label text="Cadastro"
           style="-fx-font-family: Georgia;
                  -fx-font-weight: bold;
                  -fx-font-size: 26px;
                  -fx-text-fill: #3F51B5;">
        <padding><Insets top="4" bottom="12"/></padding>
    </Label>

    <!-- Nome -->
    <Label text="Nome"
           style="-fx-font-weight: bold;
                  -fx-font-size: 13px;
                  -fx-text-fill: #444444;">
        <VBox.margin><Insets top="6" left="2"/></VBox.margin>
    </Label>
    <TextField fx:id="nomeField"
               promptText="Seu nome completo"
               maxWidth="1.7976931348623157E308"
               style="-fx-background-color: #F0F0F0;
                      -fx-background-radius: 10;
                      -fx-border-color: transparent;
                      -fx-font-size: 14px;
                      -fx-padding: 10 14 10 14;
                      -fx-pref-height: 44px;"/>

    <Region minHeight="8"/>

    <!-- E-Mail -->
    <Label text="E-Mail"
           style="-fx-font-weight: bold;
                  -fx-font-size: 13px;
                  -fx-text-fill: #444444;">
        <VBox.margin><Insets top="6" left="2"/></VBox.margin>
    </Label>
    <TextField fx:id="emailField"
               promptText="seu@email.com"
               maxWidth="1.7976931348623157E308"
               style="-fx-background-color: #F0F0F0;
                      -fx-background-radius: 10;
                      -fx-border-color: transparent;
                      -fx-font-size: 14px;
                      -fx-padding: 10 14 10 14;
                      -fx-pref-height: 44px;"/>

    <Region minHeight="8"/>

    <!-- Senha -->
    <Label text="Senha"
           style="-fx-font-weight: bold;
                  -fx-font-size: 13px;
                  -fx-text-fill: #444444;">
        <VBox.margin><Insets top="6" left="2"/></VBox.margin>
    </Label>
    <PasswordField fx:id="senhaField"
                   promptText="••••••••"
                   maxWidth="1.7976931348623157E308"
                   style="-fx-background-color: #F0F0F0;
                          -fx-background-radius: 10;
                          -fx-border-color: transparent;
                          -fx-font-size: 14px;
                          -fx-padding: 10 14 10 14;
                          -fx-pref-height: 44px;"/>

    <Region minHeight="8"/>

    <!-- Data de Nascimento -->
    <Label text="Data de Nascimento"
           style="-fx-font-weight: bold;
                  -fx-font-size: 13px;
                  -fx-text-fill: #444444;">
        <VBox.margin><Insets top="6" left="2"/></VBox.margin>
    </Label>
    <DatePicker fx:id="dataField"
                promptText="dd/mm/aaaa"
                maxWidth="1.7976931348623157E308"
                style="-fx-background-color: #F0F0F0;
                       -fx-background-radius: 10;
                       -fx-border-color: transparent;
                       -fx-font-size: 14px;
                       -fx-pref-height: 44px;"/>

    <Region minHeight="16"/>

    <!-- label aviso -->
    <Label fx:id="labelAviso"
           text=""
           wrapText="true"
           maxWidth="1.7976931348623157E308"
           style="-fx-font-size: 12px; -fx-text-fill: #C62828;"/>

    <!-- Botão Cadastrar -->
    <Button fx:id="botaoCadastro"
            text="Cadastrar"
            maxWidth="1.7976931348623157E308"
            onAction="#cadastrar"
            style="-fx-background-color: #283593;
                   -fx-text-fill: white;
                   -fx-font-size: 15px;
                   -fx-font-weight: bold;
                   -fx-background-radius: 12;
                   -fx-cursor: hand;
                   -fx-pref-height: 48px;
                   -fx-effect: dropshadow(gaussian, rgba(26,35,126,0.4), 8, 0, 0, 0);"/>

    <Region minHeight="16"/>

    <!-- link pra voltar login -->
    <VBox alignment="CENTER" spacing="2">
        <Label text="Já possui uma conta?"
               style="-fx-font-size: 13px; -fx-text-fill: #444444;"/>
        <Hyperlink text="Faça login aqui"
                   onAction="#irParaLogin"
                   style="-fx-font-size: 13px;
                          -fx-text-fill: #3F51B5;
                          -fx-border-color: transparent;
                          -fx-padding: 0;"/>
    </VBox>

</VBox>
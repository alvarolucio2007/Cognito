<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="database.controller.TesteNivelamentoController"
            fitToWidth="true"
            hbarPolicy="NEVER"
            style="-fx-background-color: linear-gradient(to bottom, #E8EAF6, #C5CAE9);
                   -fx-background: linear-gradient(to bottom, #E8EAF6, #C5CAE9);">

    <VBox spacing="24" style="-fx-background-color: transparent;">
        <padding><Insets top="40" right="28" bottom="40" left="28"/></padding>

        <!-- Título -->
        <Label text="Teste de nivelamento"
               wrapText="true"
               maxWidth="1.7976931348623157E308"
               style="-fx-font-family: Georgia;
                      -fx-font-weight: bold;
                      -fx-font-size: 26px;
                      -fx-text-fill: #1A237E;
                      -fx-alignment: CENTER;
                      -fx-text-alignment: CENTER;"/>

        <Label text="Antes de prosseguir, queremos fazer algumas perguntas"
               wrapText="true"
               maxWidth="1.7976931348623157E308"
               style="-fx-font-size: 16px;
                      -fx-text-fill: #3F51B5;
                      -fx-alignment: CENTER;
                      -fx-text-alignment: CENTER;"/>

        <Separator/>

        <!-- Pergunta 1: Data de nascimento -->
        <VBox spacing="10">
            <Label text="Sua data de nascimento"
                   wrapText="true"
                   style="-fx-font-size: 16px;
                          -fx-text-fill: #333333;
                          -fx-alignment: CENTER;
                          -fx-text-alignment: CENTER;"
                   maxWidth="1.7976931348623157E308"/>
            <HBox spacing="10" alignment="CENTER">
                <TextField fx:id="diaField"
                           promptText="Dia"
                           prefWidth="90"
                           style="-fx-background-color: white;
                                  -fx-background-radius: 10;
                                  -fx-font-size: 15px;
                                  -fx-pref-height: 48px;
                                  -fx-alignment: CENTER;"/>
                <TextField fx:id="mesField"
                           promptText="Mês"
                           prefWidth="90"
                           style="-fx-background-color: white;
                                  -fx-background-radius: 10;
                                  -fx-font-size: 15px;
                                  -fx-pref-height: 48px;
                                  -fx-alignment: CENTER;"/>
                <TextField fx:id="anoField"
                           promptText="Ano"
                           prefWidth="90"
                           style="-fx-background-color: white;
                                  -fx-background-radius: 10;
                                  -fx-font-size: 15px;
                                  -fx-pref-height: 48px;
                                  -fx-alignment: CENTER;"/>
            </HBox>
        </VBox>

        <Separator/>

        <!-- Pergunta 2: Tempo com celular -->
        <VBox spacing="10">
            <Label text="A quanto tempo possui um telefone celular?"
                   wrapText="true"
                   maxWidth="1.7976931348623157E308"
                   style="-fx-font-size: 16px;
                          -fx-text-fill: #333333;
                          -fx-alignment: CENTER;
                          -fx-text-alignment: CENTER;"/>
            <DatePicker fx:id="tempoCelularField"
                        promptText="Data"
                        maxWidth="1.7976931348623157E308"
                        style="-fx-background-color: white;
                               -fx-background-radius: 10;
                               -fx-font-size: 15px;
                               -fx-pref-height: 48px;"/>
        </VBox>

        <Separator/>

        <!-- Pergunta 3: Usou assistente de voz -->
        <VBox spacing="14">
            <Label text="Você já falou (&quot;Ok google&quot; ou &quot;E aí, siri&quot;) para executar alguma ajuda?"
                   wrapText="true"
                   maxWidth="1.7976931348623157E308"
                   style="-fx-font-size: 16px;
                          -fx-text-fill: #333333;
                          -fx-alignment: CENTER;
                          -fx-text-alignment: CENTER;"/>
            <HBox spacing="16" alignment="CENTER">
                <ToggleButton fx:id="btnSimVoz"
                              text="Sim"
                              prefWidth="120"
                              onAction="#selecionarSimVoz"
                              style="-fx-background-color: white;
                                     -fx-text-fill: #3F51B5;
                                     -fx-font-size: 15px;
                                     -fx-background-radius: 12;
                                     -fx-pref-height: 48px;
                                     -fx-border-color: #3F51B5;
                                     -fx-border-radius: 12;
                                     -fx-cursor: hand;"/>
                <ToggleButton fx:id="btnNaoVoz"
                              text="Não"
                              prefWidth="120"
                              onAction="#selecionarNaoVoz"
                              style="-fx-background-color: #1A237E;
                                     -fx-text-fill: white;
                                     -fx-font-size: 15px;
                                     -fx-background-radius: 12;
                                     -fx-pref-height: 48px;
                                     -fx-cursor: hand;"/>
            </HBox>
        </VBox>

        <Separator/>

        <!-- Label de aviso -->
        <Label fx:id="labelAviso"
               text=""
               wrapText="true"
               maxWidth="1.7976931348623157E308"
               style="-fx-font-size: 13px;
                      -fx-text-fill: #C62828;
                      -fx-alignment: CENTER;"/>

        <!-- Botão Continuar -->
        <Button text="Continuar"
                maxWidth="1.7976931348623157E308"
                onAction="#continuar"
                style="-fx-background-color: #283593;
                       -fx-text-fill: white;
                       -fx-font-size: 17px;
                       -fx-font-weight: bold;
                       -fx-background-radius: 14;
                       -fx-pref-height: 56px;
                       -fx-cursor: hand;
                       -fx-effect: dropshadow(gaussian, rgba(26,35,126,0.4), 8, 0, 0, 0);"/>

    </VBox>
</ScrollPane>

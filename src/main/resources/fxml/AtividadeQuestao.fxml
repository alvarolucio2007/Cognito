<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="database.controller.AtividadeQuestaoController"
      style="-fx-background-color: white;"
      prefWidth="440.0" prefHeight="950.0" spacing="0">

    <!-- Cabeçalho -->
    <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: white;">
        <padding>
            <Insets top="50.0" right="24.0" bottom="15.0" left="24.0"/>
        </padding>
        <Button fx:id="botaoVoltar" text="← Voltar" onAction="#voltarAction"
                style="-fx-background-color: #000986; -fx-text-fill: white; -fx-font-size: 14px;
                       -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;"
                prefWidth="100.0" prefHeight="38.0"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="labelNumeroQuestao" text="Questão 1/5"
               style="-fx-text-fill: #64748B; -fx-font-size: 14px; -fx-font-weight: bold;"/>
    </HBox>

    <!-- Conteúdo rolável -->
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS"
                style="-fx-background: white; -fx-background-color: transparent;">
        <content>
            <VBox spacing="20.0" style="-fx-background-color: white; -fx-padding: 10 24 40 24;">

                <!-- Box da Pergunta -->
                <VBox style="-fx-background-color: #0D1B54; -fx-background-radius: 20; -fx-padding: 6;">
                    <VBox style="-fx-background-color: #D6E0FF; -fx-background-radius: 16; -fx-padding: 24;" alignment="CENTER">
                        <Label fx:id="labelPergunta"
                               text="Qual destas opções melhor descreve a Inteligência Artificial no seu cotidiano?"
                               wrapText="true"
                               textAlignment="CENTER"
                               style="-fx-text-fill: #0D1B54; -fx-font-size: 17px; -fx-font-weight: bold;"
                               maxWidth="1.7976931348623157E308"/>
                    </VBox>
                </VBox>

                <!-- Alternativas -->
                <VBox fx:id="boxAlternativas" spacing="12.0"/>

                <!-- Botão Responder -->
                <Button fx:id="botaoResponder" text="Responder" onAction="#responder"
                        maxWidth="1.7976931348623157E308"
                        style="-fx-background-color: #001EE4; -fx-text-fill: white; -fx-font-size: 17px;
                               -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;
                               -fx-pref-height: 54px;"/>

                <!-- Área de Feedback -->
                <VBox fx:id="areaFeedback" spacing="14.0" visible="false" managed="false"
                      style="-fx-background-color: #F8FAFC; -fx-background-radius: 20; -fx-padding: 20;">

                    <!-- Ícone + Título -->
                    <HBox alignment="CENTER" spacing="12.0">
                        <Label fx:id="labelIconeFeedback" text="✅" style="-fx-font-size: 36px;"/>
                        <VBox spacing="2.0">
                            <Label fx:id="labelTituloFeedback" text="Correto!"
                                   style="-fx-text-fill: #16A34A; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                            <Label fx:id="labelSubtituloFeedback" text="Muito bem! Continue assim."
                                   style="-fx-text-fill: #64748B; -fx-font-size: 13px;"/>
                        </VBox>
                    </HBox>

                    <!-- Mascote de Feedback Dinâmico do Figma -->
                    <HBox alignment="CENTER">
                        <StackPane>
                            <children>
                                <ImageView fx:id="imgMascote" fitWidth="120.0" fitHeight="150.0" preserveRatio="true"/>
                                <Label fx:id="labelMascote" text="🦉" style="-fx-font-size: 64px;"/> <!-- Placeholder em Emoji -->
                            </children>
                        </StackPane>
                    </HBox>

                    <!-- Explicação técnica -->
                    <VBox style="-fx-background-color: #EFF6FF; -fx-background-radius: 14; -fx-padding: 16;">
                        <Label text="Explicação:" style="-fx-text-fill: #1E40AF; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                        <Label fx:id="labelExplicacao"
                               text=""
                               wrapText="true"
                               style="-fx-text-fill: #1E3A5F; -fx-font-size: 14px; -fx-padding: 6 0 0 0;"/>
                    </VBox>

                    <!-- Botão Próxima -->
                    <Button fx:id="botaoProxima" text="Próxima Questão →" onAction="#proximaQuestaoAction"
                            maxWidth="1.7976931348623157E308"
                            style="-fx-background-color: #001EE4; -fx-text-fill: white; -fx-font-size: 16px;
                                   -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;
                                   -fx-pref-height: 50px;"/>
                </VBox>

            </VBox>
        </content>
    </ScrollPane>
</VBox>
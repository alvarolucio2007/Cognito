<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="database.controller.VideoAulaController"
      style="-fx-background-color: white; -fx-background-radius: 20;"
      prefWidth="440.0" prefHeight="950.0" spacing="0">

    <!-- Cabeçalho com Botão Voltar -->
    <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: white;">
        <padding>
            <Insets top="50.0" right="24.0" bottom="15.0" left="24.0"/>
        </padding>
        <Button fx:id="botaoVoltar" text="← Voltar" onAction="#voltar"
                style="-fx-background-color: #000986; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;"
                prefWidth="100.0" prefHeight="38.0"/>
    </HBox>

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS"
                style="-fx-background: white; -fx-background-color: transparent;">
        <content>
            <VBox spacing="25.0" style="-fx-background-color: white; -fx-padding: 10 24 30 24;">

                <!-- Título da Vídeo Aula -->
                <Label fx:id="tituloAulaLabel" text="Introdução ao uso de IA e suas aplicações" 
                       style="-fx-text-fill: #000000; -fx-font-size: 20px; -fx-font-weight: bold; -fx-font-family: 'Poppins';" wrapText="true"/>

                <!-- Container do Vídeo Player Simulável -->
                <VBox spacing="10.0" style="-fx-background-color: #E2E8F0; -fx-background-radius: 20; -fx-padding: 15;">
                    <!-- Área Física do Vídeo -->
                    <StackPane prefHeight="220.0" style="-fx-background-color: #0F172A; -fx-background-radius: 15; -fx-overflow: hidden;">
                        <children>
                            <ImageView fx:id="videoPlaceholder" fitWidth="360.0" fitHeight="220.0" preserveRatio="false"/>
                            <Label fx:id="statusVideoLabel" text="Vídeo Pausado" style="-fx-text-fill: white; -fx-font-size: 16px;"/>
                        </children>
                    </StackPane>

                    <!-- Controles de Reprodução -->
                    <HBox alignment="CENTER" spacing="15.0">
                        <Button fx:id="botaoPlayPause" text="▶ Play" onAction="#alternarPlayPause"
                                style="-fx-background-color: #0d179f; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 15; -fx-cursor: hand;"
                                prefWidth="80.0" prefHeight="30.0"/>
                        
                        <!-- Barra de Progresso Interativa -->
                        <Slider fx:id="sliderVideo" min="0" max="120" value="0" HBox.hgrow="ALWAYS"
                                style="-fx-cursor: hand;"/>
                        
                        <Label fx:id="tempoLabel" text="00:00" style="-fx-text-fill: #000763; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                    </HBox>
                </VBox>

                <!-- Seção de Conteúdo -->
                <VBox spacing="15.0">
                    <Label text="Conteúdo:" style="-fx-text-fill: #000000; -fx-font-size: 18px; -fx-font-weight: bold; -fx-font-family: 'Poppins';"/>
                    
                    <VBox spacing="12.0" style="-fx-background-color: #F1F5F9; -fx-background-radius: 17; -fx-padding: 20;">
                        <!-- Atividade 1 -->
                        <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #000220; -fx-background-radius: 10; -fx-padding: 12 15 12 15;">
                            <Label text="Atividade 1" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-font-family: 'Quicksand';" HBox.hgrow="ALWAYS"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="📥" onAction="#abrirAtividade1"
                                    style="-fx-background-color: #354acd; -fx-text-fill: white; -fx-background-radius: 12; -fx-cursor: hand;" prefWidth="35.0" prefHeight="30.0"/>
                        </HBox>

                        <!-- Atividade 2 -->
                        <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #000220; -fx-background-radius: 10; -fx-padding: 12 15 12 15;">
                            <Label text="Atividade 2" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-font-family: 'Quicksand';" HBox.hgrow="ALWAYS"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="📥" onAction="#abrirAtividade2"
                                    style="-fx-background-color: #354acd; -fx-text-fill: white; -fx-background-radius: 12; -fx-cursor: hand;" prefWidth="35.0" prefHeight="30.0"/>
                        </HBox>

                        <!-- Avaliação 1/2 -->
                        <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #000220; -fx-background-radius: 10; -fx-padding: 12 15 12 15;">
                            <Label text="Avaliação 1/2" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-font-family: 'Quicksand';" HBox.hgrow="ALWAYS"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="📥" onAction="#abrirAvaliacao1"
                                    style="-fx-background-color: #35cd60; -fx-text-fill: white; -fx-background-radius: 12; -fx-cursor: hand;" prefWidth="35.0" prefHeight="30.0"/>
                        </HBox>

                        <!-- Avaliação 2/2 -->
                        <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #000220; -fx-background-radius: 10; -fx-padding: 12 15 12 15;">
                            <Label text="Avaliação 2/2" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-font-family: 'Quicksand';" HBox.hgrow="ALWAYS"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="📥" onAction="#abrirAvaliacao2"
                                    style="-fx-background-color: #354acd; -fx-text-fill: white; -fx-background-radius: 12; -fx-cursor: hand;" prefWidth="35.0" prefHeight="30.0"/>
                        </HBox>
                    </VBox>
                </VBox>

                <!-- Botão Emitir Certificado -->
                <VBox spacing="8.0" alignment="CENTER">
                    <Button fx:id="botaoCertificado" text="Emitir Certificado" onAction="#emitirCertificado"
                            style="-fx-background-color: #7c8eff; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 11; -fx-cursor: hand;"
                            prefWidth="320.0" prefHeight="55.0"/>
                    <Label fx:id="labelStatusModulo" text="🔒 Primeiro complete o módulo" style="-fx-text-fill: #475569; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                </VBox>

                <!-- Botão de Salvar e Voltar -->
                <HBox alignment="CENTER">
                    <Button text="Salvar e Voltar" onAction="#salvarEVoltar"
                            style="-fx-background-color: #000dc9; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"
                            prefWidth="234.0" prefHeight="56.0"/>
                </HBox>

            </VBox>
        </content>
    </ScrollPane>
</VBox>
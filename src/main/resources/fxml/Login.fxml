<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="database.controller.LoginController"
      alignment="TOP_CENTER"
      spacing="15"
      style="-fx-background-color: white; -fx-background-radius: 20;"
      prefWidth="440.0" prefHeight="950.0">

    <padding>
        <Insets top="80" right="32" bottom="40" left="32"/>
    </padding>

    <!-- Logotipo Oficial do Sistema do Figma -->
    <StackPane>
        <padding><Insets bottom="10"/></padding>
        <ImageView fitWidth="160.0" fitHeight="160.0" preserveRatio="true">
            <image>
                <Image url="@/images/logo_sistema.png"/>
            </image>
        </ImageView>
    </StackPane>

    <!-- Título -->
    <Label text="Login"
           style="-fx-font-family: Poppins;
                  -fx-font-weight: bold;
                  -fx-font-size: 26px;
                  -fx-text-fill: #0011ff;">
        <padding><Insets bottom="15"/></padding>
    </Label>

    <!-- Campo: E-Mail -->
    <VBox spacing="6" alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308">
        <Label text="E-Mail" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: black;"/>
        <TextField fx:id="emailField" promptText="seu@email.com"
                   style="-fx-background-color: #F0F0F0; -fx-background-radius: 10; -fx-font-size: 15px; -fx-padding: 10 14 10 14; -fx-pref-height: 44px;"/>
    </VBox>

    <!-- Campo: Senha -->
    <VBox spacing="6" alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308">
        <Label text="Senha" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: black;"/>
        <PasswordField fx:id="senhaField" promptText="••••••••"
                       style="-fx-background-color: #F0F0F0; -fx-background-radius: 10; -fx-font-size: 15px; -fx-padding: 10 14 10 14; -fx-pref-height: 44px;"/>
    </VBox>

    <Region minHeight="20"/>

    <!-- Botão de Login -->
    <Button fx:id="botaoLogin" text="Login" onAction="#login"
            maxWidth="1.7976931348623157E308"
            style="-fx-background-color: #00108d; -fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand; -fx-pref-height: 54px;"/>

    <Region minHeight="20"/>

    <!-- Link de Cadastro -->
    <VBox alignment="CENTER" spacing="4">
        <Label text="Não possui uma conta?" style="-fx-font-size: 13px; -fx-text-fill: black;"/>
        <Hyperlink text="Clique aqui e crie uma" onAction="#irParaCadastro"
                   style="-fx-font-size: 14px; -fx-text-fill: #0011ff; -fx-font-weight: bold; -fx-border-color: transparent; -fx-padding: 0;"/>
    </VBox>
</VBox>